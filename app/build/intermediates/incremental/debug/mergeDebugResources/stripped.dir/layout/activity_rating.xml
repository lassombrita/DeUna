<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <TextView android:id="@+id/tvTitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="48dp" android:text="Califica el servicio"
        android:textSize="24sp" android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tvProName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:textColor="#64748B"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout android:id="@+id/layoutStars"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="32dp" android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvProName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton android:id="@+id/star1"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_star_empty" android:background="@android:color/transparent" />
        <ImageButton android:id="@+id/star2"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_star_empty" android:background="@android:color/transparent" />
        <ImageButton android:id="@+id/star3"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_star_empty" android:background="@android:color/transparent" />
        <ImageButton android:id="@+id/star4"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_star_empty" android:background="@android:color/transparent" />
        <ImageButton android:id="@+id/star5"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@drawable/ic_star_empty" android:background="@android:color/transparent" />
    </LinearLayout>

    <TextView android:id="@+id/tvRecomienda"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="32dp" android:text="¿Recomendarías a este profesional?"
        app:layout_constraintTop_toBottomOf="@id/layoutStars"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout android:id="@+id/layoutRecomienda"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="16dp" android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tvRecomienda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btnSiRecomienda"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Sí" android:layout_marginEnd="16dp" />
        <Button android:id="@+id/btnNoRecomienda"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No" />
    </LinearLayout>

    <Button android:id="@+id/btnEnviar"
        android:layout_width="0dp" android:layout_height="56dp"
        android:layout_margin="16dp" android:text="Enviar Calificación"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>