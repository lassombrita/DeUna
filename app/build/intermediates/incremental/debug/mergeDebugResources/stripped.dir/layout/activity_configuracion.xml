<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Configuración"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold" />

    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- APARIENCIA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apariencia"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgTema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbTemaClaro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Claro" />

                <RadioButton
                    android:id="@+id/rbTemaOscuro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Oscuro" />

                <RadioButton
                    android:id="@+id/rbTemaSistema"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sistema" />
            </RadioGroup>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swModoGrises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Modo escala de grises"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tamaño de texto"
                android:textColor="#1F2937" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderTexto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0.8"
                android:valueTo="1.4"
                android:stepSize="0.1" />

            <!-- IDIOMA -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Idioma"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swIdiomaIngles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="English / Inglés"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <!-- NOTIFICACIONES -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notificaciones"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swNotifMensajes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Mensajes nuevos"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swNotifServicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Actualizaciones de servicios"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swNotifPromociones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Promociones y ofertas"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swNotifEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumen por email"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <!-- PRIVACIDAD -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Privacidad"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swCompartirUbicacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Compartir ubicación"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swHistorialBusqueda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar historial de búsqueda"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <Button
                android:id="@+id/btnBorrarHistorial"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Borrar historial"
                android:textColor="#DC2626" />

            <!-- SEGURIDAD -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E2E8F0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Seguridad"
                android:textColor="#2563EB"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/swBiometrico"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Autenticación biométrica"
                android:textColor="#1F2937"
                android:textOn=""
                android:textOff=""
                app:showText="false" />

            <!-- ACERCA DE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#E2E8F0" />

            <TextView
                android:id="@+id/rowTerminos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:text="Términos y condiciones"
                android:textColor="#1F2937" />

            <TextView
                android:id="@+id/rowPolitica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="12dp"
                android:text="Política de privacidad"
                android:textColor="#1F2937" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="Versión 1.0.0"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
