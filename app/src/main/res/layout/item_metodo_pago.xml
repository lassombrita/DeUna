<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvIcono"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#F1F5F9"
            android:gravity="center"
            android:text="🏠"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvPrincipal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="•••• 1234"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/chipPrincipal"
            app:layout_constraintStart_toEndOf="@id/tvIcono"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSecundario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Laura García · Vence 12/26"
            android:textColor="#64748B"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tvPrincipal"
            app:layout_constraintTop_toBottomOf="@id/tvPrincipal" />

        <TextView
            android:id="@+id/chipPrincipal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#DBEAFE"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="Principal"
            android:textColor="#2563EB"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
